# ==========================================
# CONFIGURAÇÕES DE DOMÍNIO (DuckDNS)
# ==========================================
DOMAIN_NAME=fdmeneses.duckdns.org
SUBDOMAIN_N8N=fdmeneses.duckdns.org
# Como o DuckDNS é limitado a um domínio grátis, 
# usaremos o mesmo para a API ou subpastas.
EVOLUTION_SERVER_URL=https://fdmeneses.duckdns.org/evolution

# ==========================================
# BANCO DE DADOS (PostgreSQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=n8n

# ==========================================
# REDIS (Cache e Fila)
# ==========================================
REDIS_PASSWORD=redis123

# ==========================================
# CONFIGURAÇÕES N8N
# ==========================================
N8N_HOST=fdmeneses.duckdns.org
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_TIMEZONE=America/Sao_Paulo
# URL completa onde os webhooks serão recebidos
N8N_WEBHOOK_URL=https://fdmeneses.duckdns.org/

# ==========================================
# EVOLUTION API
# ==========================================
EVOLUTION_PORT=8080
EVOLUTION_API_KEY=random-api-key
EVOLUTION_DB_NAME=evolution
EVOLUTION_CACHE_REDIS_PREFIX_KEY=evolution

# ==========================================
# NGINX / SSL
# ==========================================
# E-mail para avisos de renovação do SSL pelo Certbot
CERTBOT_EMAIL=email@email.com