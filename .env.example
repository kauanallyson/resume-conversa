# ==========================================
# CONFIGURAÇÕES DE DOMÍNIO (DuckDNS)
# ==========================================
DOMAIN_NAME=fdmeneses.duckdns.org
SUBDOMAIN_N8N=fdmeneses.duckdns.org
EVOLUTION_SERVER_URL=https://fdmeneses.duckdns.org/evolution

# ==========================================
# BANCO DE DADOS (PostgreSQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=n8n

# ==========================================
# REDIS (Cache e Fila)
# ==========================================
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# ==========================================
# CONFIGURAÇÕES N8N
# ==========================================
N8N_HOST=fdmeneses.duckdns.org
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_TIMEZONE=America/Sao_Paulo
N8N_WEBHOOK_URL=https://fdmeneses.duckdns.org/

# ==========================================
# EVOLUTION API
# ==========================================
EVOLUTION_PORT=8080
EVOLUTION_API_KEY=TROQUE_POR_UUID_GERADO_COM_uuidgen
EVOLUTION_DB_NAME=evolution
EVOLUTION_CACHE_REDIS_PREFIX_KEY=evolution

# ==========================================
# NGINX / SSL
# ==========================================
CERTBOT_EMAIL=TROQUE_POR_SEU_EMAIL